2026-04-23 19:34:46.642 | INFO     | app.agent.nodes.generate_sql:generate_sql:37 - 生成的SQL：SELECT t.region_name, t.product_name, t.sales_rank
FROM (
    SELECT 
        r.region_name,
        p.product_name,
        SUM(f.order_quantity) AS total_quantity,
        ROW_NUMBER() OVER (PARTITION BY r.region_name ORDER BY SUM(f.order_quantity) DESC) AS sales_rank
    FROM fact_order f
    JOIN dim_region r ON f.region_id = r.region_id
    JOIN dim_product p ON f.product_id = p.product_id
    GROUP BY r.region_name, p.product_name
) t
WHERE t.sales_rank <= 3
ORDER BY t.region_name, t.sales_rank;
